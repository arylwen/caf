import React from \"react\";
import { apiGet } from \"./api.js\";

const SURFACES = [
  {
    id: \"catalog\",
    label: \"Catalog\",
    primaryActions: [\"Create widget\", \"Review widget details\"],
  },
  {
    id: \"collections\",
    label: \"Collections\",
    primaryActions: [\"New collection\", \"Publish\"],
  },
  {
    id: \"admin\",
    label: \"Admin\",
    primaryActions: [\"Manage roles\", \"Update tenant settings\"],
  },
];

export default function App() {
  const [status, setStatus] = React.useState({ state: \"idle\", message: \"\" });

  const checkRuntime = React.useCallback(async () => {
    setStatus({ state: \"loading\", message: \"Checking AP and CP health...\" });
    try {
      const [ap, cp] = await Promise.all([apiGet(\"/api/health\"), apiGet(\"/cp/health\")]);
      setStatus({ state: \"success\", message: "'`AP ${JSON.stringify(ap)} | CP ${JSON.stringify(cp)}` });
    } catch (error) {
      setStatus({ state: "error", message: String(error.message || error) });
    }
  }, []);

  React.useEffect(() => {
    checkRuntime();
  }, [checkRuntime]);

  return (
    <main style={{ fontFamily: "ui-sans-serif, system-ui", margin: "0 auto", maxWidth: 1120, padding: "1.5rem" }}>
      <header style={{ marginBottom: "1rem" }}>
        <h1 style={{ marginBottom: "0.25rem" }}>codex-saas UX lane</h1>
        <p style={{ marginTop: 0 }}>Separate richer UX lane aligned to React, Vite, and shadcn component-system posture.</p>
      </header>

      <section style={{ border: "1px solid #d0d7de", borderRadius: "0.5rem", padding: "1rem", marginBottom: "1rem" }}>
        <h2 style={{ marginTop: 0 }}>Runtime contract probe</h2>
        <button type="button" onClick={checkRuntime}>Refresh runtime status</button>
        <p aria-live="polite" style={{ marginBottom: 0 }}>{status.message}</p>
      </section>

      <section style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(240px, 1fr))", gap: "0.75rem" }}>
        {SURFACES.map((surface) => (
          <article key={surface.id} style={{ border: "1px solid #d0d7de", borderRadius: "0.5rem", padding: "0.75rem" }}>
            <h3 style={{ marginTop: 0 }}>{surface.label}</h3>
            <ul>
              {surface.primaryActions.map((action) => (
                <li key={action}>{action}</li>
              ))}
            </ul>
          </article>
        ))}
      </section>
    </main>
  );
}
