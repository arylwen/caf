  - task_id: TG-25-ui-page-widget_versions
    title: Implement UI page for widget_versions resource
    required_capabilities:
      - ui_frontend_scaffolding
    depends_on:
      - TG-15-ui-shell
      - TG-20-api-boundary-widget_versions
    inputs:
