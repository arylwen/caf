title: "CAF Layer 6 Architecture Shape Parameters (v1)"
type: object
additionalProperties: false

required:
  - schema_version
  - instance_name
  - template_instances

properties:
  schema_version:
    type: string
    const: "architecture_shape_parameters_v1"
    description: "Schema discriminator."

  instance_name:
    type: string
    minLength: 1
    description: "Reference architecture instance name (folder name)."

  created_at:
    type: string
    description: "ISO-8601 timestamp. Optional but recommended."

  template_instances:
    type: array
    minItems: 1
    description: "List of instantiated templates and their pinned parameter values."
    items:
      type: object
      additionalProperties: false
      required:
        - template_id
        - template_version
        - pins
      properties:
        template_id:
          type: string
          minLength: 1
          description: "Template identifier (e.g., CP, AP, DP, AI, ST)."

        template_version:
          type: string
          minLength: 1
          description: "Template version string (e.g., v1)."

        pins:
          type: object
          description: |
            Pinned parameter values for this template instance.
            Structural validation checks shape only; semantic validation must enforce:
            - completeness (all exposed parameters pinned)
            - allowed values membership
            - pin key prefix consistency with template_id
          additionalProperties:
            type: string
            minLength: 1
          propertyNames:
            type: string
            pattern: "^[A-Z]{2,5}-[0-9]{1,3}$"
            description: "Parameter ID pattern (e.g., CP-1, AP-6, ST-3)."

  meta:
    type: object
    description: "Optional metadata; not used for architectural semantics."
    additionalProperties: true

