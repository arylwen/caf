FROM node:20-alpine AS build
WORKDIR /workspace

COPY code/ux/package.json ./package.json
RUN npm install --no-audit --no-fund
COPY code/ux/ ./
RUN npm run build

FROM nginx:1.27-alpine
COPY docker/nginx.ux.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/dist /usr/share/nginx/html
EXPOSE 80
