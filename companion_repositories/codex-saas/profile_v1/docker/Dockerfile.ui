# CAF_TRACE: generated_by=Contura Architecture Framework (CAF); task_id=TG-90-runtime-wiring; capability=runtime_wiring; instance=codex-saas; trace_anchor=pattern_obligation_id:O-TBP-UI-REACT-VITE-01-ui-build-container
FROM node:20-alpine AS build

WORKDIR /workspace/code/ui

COPY code/ui/package*.json ./
RUN npm install

COPY code/ui/ ./
# vite build output is materialized by the UI build stage.
RUN npm run build

FROM nginx:1.27-alpine

COPY docker/nginx.ui.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/code/ui/dist /usr/share/nginx/html
