      focus_areas:
        - architecture_alignment
        - correctness
        - security
      constraints_notes: >-
        Semantic acceptance sources: TBP:TBP-AUTH-MOCK-01/G-AUTH-MOCK-CONTRACT-REALIZATION;
        TBP:TBP-AUTH-MOCK-01/G-AUTH-MOCK-HEADER-PRECEDENCE-COHERENCE

        Resolved rails (platform.auth_mode=mock): platform.auth_mode=mock
