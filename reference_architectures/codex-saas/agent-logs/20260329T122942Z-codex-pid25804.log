              name: Policy Version
              fields:
                - name: policy_version_id
                  type: string
                - name: policy_id
                  type: string
                - name: version_label
                  type: string
                - name: activation_state
                  type: string
            - entity_id: APPROVAL_DECISION
              name: Approval Decision
              fields:
                - name: approval_decision_id
                  type: string
                - name: subject_type
                  type: string
                - name: subject_id
                  type: string
                - name: decision
                  type: string
    - context_id: EXECUTION_AND_EVIDENCE
      name: Execution and Evidence
      aggregates:
        - aggregate_id: EXECUTION_RECORD
          name: Execution Record
          persistence:
            required: true
          entities:
            - entity_id: EXECUTION_RECORD
              name: Execution Record
              fields:
                - name: execution_record_id
                  type: string
                - name: tenant_id
                  type: string
                - name: subject_type
                  type: string
                - name: outcome
                  type: string
            - entity_id: EVIDENCE_RECORD
              name: Evidence Record
              fields:
                - name: evidence_record_id
                  type: string
                - name: execution_record_id
                  type: string
                - name: evidence_type
                  type: string
                - name: emitted_at
                  type: datetime
    - context_id: RETENTION_AND_LIFECYCLE
      name: Retention and Lifecycle
      aggregates:
        - aggregate_id: RETENTION_RULE
          name: Retention Rule
          persistence:
            required: true
          entities:
            - entity_id: RETENTION_RULE
              name: Retention Rule
              fields:
                - name: retention_rule_id
                  type: string
                - name: target_type
                  type: string
                - name: retention_period_days
                  type: integer
                - name: status
                  type: string
        - aggregate_id: DELETION_REQUEST
          name: Deletion Request
          persistence:
            required: true
          entities:
            - entity_id: DELETION_REQUEST
              name: Deletion Request
              fields:
                - name: deletion_request_id
                  type: string
                - name: tenant_id
                  type: string
                - name: target_type
                  type: string
                - name: target_id
                  type: string
                - name: status
                  type: string
  use_cases:
