{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contura://caf/schemas/architecture_shape_proposed_rationale/v1",
  "title": "CAF Phase 8 Architecture Shape Proposal Rationale (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_prd_path", "template_instances"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "architecture_shape_parameters_proposed_rationale_v1"
    },
    "source_prd_path": {
      "type": "string",
      "minLength": 1
    },
    "template_instances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["template_id", "template_version", "pins"],
        "properties": {
          "template_id": { "type": "string", "minLength": 1 },
          "template_version": { "type": "string", "minLength": 1 },
          "pins": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": {
              "type": "string",
              "pattern": "^[A-Z]{2,5}-[0-9]{1,3}$"
            },
            "additionalProperties": {
              "$ref": "#/definitions/pinRationale"
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "definitions": {
    "pinRationale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_value", "confidence", "rationale", "evidence"],
      "properties": {
        "selected_value": { "type": "string", "minLength": 1 },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missing_info": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
