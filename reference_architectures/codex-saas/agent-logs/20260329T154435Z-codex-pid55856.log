+        - Workspace hierarchy should reduce context switching fatigue.
+      rationale: Clear shell hierarchy supports medium-dense operational use.
+state_and_recovery:
+  key_states:
+    - empty
+    - loading
+    - ready
+    - validation_error
+    - permission_denied
+    - save_success
+    - publish_pending
+    - publish_complete
+    - update_failed
