      tags: draft.tags
        .split(",")
        .map((value) => value.trim())
        .filter(Boolean),
      status: draft.status,
    };

    try {
      await updateWidget(selectedWidget.widget_id, payload, authState);
      setStatus({ state: "success", message: "Save complete. Updated state is now durable." });
